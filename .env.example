# YouTube embed configuration
# URL where the optimized YouTube embed player is hosted
VITE_EMBED_URL=https://sco-tt.github.io/segment-studio/

# Origin for cross-origin messaging with the embed
VITE_EMBED_ORIGIN=https://sco-tt.github.io

# YouTube to MP3 Download Feature
# Set to 'true' to enable MP3 download functionality with embedded yt-dlp
# yt-dlp binary is automatically downloaded and embedded during build when enabled
# WARNING: Ensure you comply with YouTube's Terms of Service and copyright laws
DOWNLOAD_MP3=false