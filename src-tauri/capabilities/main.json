{
  "identifier": "main",
  "description": "Main application capabilities for Segment Studio",
  "remote": {
    "urls": []
  },
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:window:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:path:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-create",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:scope-app-recursive"
  ]
}